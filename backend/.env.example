NODE_ENV=development
PORT=4000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sinarms

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

CORS_ORIGIN=http://localhost:5173

# FastAPI AI engine. Port 8001 (8000 is often blocked on Windows).
AI_ENGINE_URL=http://127.0.0.1:8001
AI_ENGINE_TIMEOUT_MS=1500
AI_ENGINE_DISABLED=0

# OpenRouter polish layer (optional). Leave blank to skip LLM rewriting.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_TIMEOUT_MS=2000
