# SINARMS production environment — copy to .env.prod on the host and fill in.
#   cp .env.prod.example .env.prod && chmod 600 .env.prod
# .env.prod is gitignored and must live only on the server (survives git reset).

# ---- Backend ----
NODE_ENV=production
PORT=4000
BIND_HOST=127.0.0.1

# Host MySQL (reused — do NOT run a db container). Create a dedicated user.
# Containers run on the docker bridge and reach the host via the gateway IP
# 172.17.0.1 (compose overrides DB_HOST to this); the MySQL user must allow
# the 172.17.% host. For a native (non-docker) run, use 127.0.0.1.
DB_HOST=172.17.0.1
DB_PORT=3306
DB_USER=sinarms
DB_PASSWORD=__CHANGE_ME__
DB_NAME=sinarms

# Generate with: openssl rand -hex 32
JWT_SECRET=__CHANGE_ME__
JWT_EXPIRES_IN=8h

# Public origin allowed to call the API / open the websocket.
CORS_ORIGIN=https://sinarms.isiri.rw

# AI engine reachable via the docker bridge gateway (compose overrides this).
AI_ENGINE_URL=http://172.17.0.1:8001
AI_ENGINE_TIMEOUT_MS=1500
AI_ENGINE_DISABLED=0

# Optional OpenRouter polish layer. Leave blank to skip LLM rewriting.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_TIMEOUT_MS=2000

# ---- AI engine ----
# AI_HOST is overridden to 0.0.0.0 by compose (bind inside the container);
# the port is published on the host loopback only.
AI_HOST=127.0.0.1
AI_PORT=8001
SINARMS_BACKEND_URL=http://172.17.0.1:4000

# ---- Frontend (compile-time, baked into the static bundle) ----
VITE_API_BASE_URL=https://api-sinarms.isiri.rw/api
VITE_WS_URL=https://api-sinarms.isiri.rw
