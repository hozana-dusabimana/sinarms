# SINARMS production environment — copy to .env.prod on the host and fill in.
#   cp .env.prod.example .env.prod && chmod 600 .env.prod
# .env.prod is gitignored and must live only on the server (survives git reset).

# ---- Backend ----
NODE_ENV=production
PORT=4000
BIND_HOST=127.0.0.1

# Host MySQL (reused — do NOT run a db container). Create a dedicated user.
# backend/ai use host networking, so 127.0.0.1 reaches the host MySQL directly.
# Create the MySQL user with `mysql -h127.0.0.1 -P3306 -uroot -p<masterpw>`
# (the CloudPanel master password is for root over TCP, NOT the unix socket).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=sinarms
DB_PASSWORD=__CHANGE_ME__
DB_NAME=sinarms

# Generate with: openssl rand -hex 32
JWT_SECRET=__CHANGE_ME__
JWT_EXPIRES_IN=8h

# Public origin allowed to call the API / open the websocket.
CORS_ORIGIN=https://sinarms.isiri.rw

# AI engine reachable on the host network (8002 — 8000/8001 are taken on this
# box by the co-hosted CloudPanel/AIRA stack).
AI_ENGINE_URL=http://127.0.0.1:8002
AI_ENGINE_TIMEOUT_MS=1500
AI_ENGINE_DISABLED=0

# Optional OpenRouter polish layer. Leave blank to skip LLM rewriting.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_TIMEOUT_MS=2000

# ---- AI engine ----
AI_HOST=127.0.0.1
AI_PORT=8002
SINARMS_BACKEND_URL=http://127.0.0.1:4000

# ---- Frontend (compile-time, baked into the static bundle) ----
# NOTE: the app's axios calls already include the `/api` prefix in each path
# (e.g. api.get('/api/bootstrap/public')), so this base URL is the bare API
# ORIGIN with NO `/api` suffix — otherwise requests double up to /api/api/...
VITE_API_BASE_URL=https://api-sinarms.isiri.rw
VITE_WS_URL=https://api-sinarms.isiri.rw
